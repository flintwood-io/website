---
import Layout from '../layouts/Layout.astro';

const LAMBDA_URL = "https://xvpfb3b7avfnh4ad5tgkev733y0ukujb.lambda-url.us-east-1.on.aws/remove";
const CF_REMOVE_URL = "https://us-east-1.console.aws.amazon.com/cloudformation/home?region=us-east-1#/stacks?filteringStatus=active&filteringText=FlinttwoodAuditRole";
---
<Layout title="Remove Flintwood access — Flintwood">

<nav class="connect-nav">
  <div class="nav-inner">
    <a class="nav-logo" href="/">
      <svg width="22" height="23" viewBox="0 0 46 48" fill="none" xmlns="http://www.w3.org/2000/svg">
        <polygon points="23,2 37,8 31,11" fill="#f8c858"/>
        <polygon points="37,8 43,22 33,26 31,11" fill="#e08535"/>
        <polygon points="43,22 37,40 23,46 15,33 33,26" fill="#b06028"/>
        <polygon points="23,46 9,40 15,33" fill="#7a3818"/>
        <polygon points="9,40 3,22 9,8 23,2 31,11 33,26 15,33" fill="#4a200e"/>
        <polygon points="23,2 26,5 23,7 20,5" fill="#fff4cc"/>
      </svg>
      <span class="logo-type">Flint<em>wood</em></span>
    </a>
    <a class="nav-contact" href="mailto:hello@flintwood.io">hello@flintwood.io</a>
  </div>
</nav>

<section id="remove">
  <div class="inner">

    <div class="remove-header">
      <div class="eyebrow">Account removal</div>
      <h1>Remove Flintwood access.</h1>
      <p class="subtitle">Two independent actions — do one or both.</p>
    </div>

    <div id="remove-steps">

      <!-- Step 1: Remove IAM role -->
      <div class="action-card">
        <div class="action-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
        </div>
        <div class="action-body">
          <h2>Remove IAM role from your AWS account</h2>
          <p>Deletes the <code>FlinttwoodAuditRole</code> CloudFormation stack from your AWS Console. This immediately revokes Flintwood's read access to your account — takes about 30 seconds.</p>
          <a class="btn btn-primary" href={CF_REMOVE_URL} target="_blank" rel="noopener">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
            Open AWS Console to delete stack
          </a>
          <div class="action-note">CloudFormation → Stacks → FlinttwoodAuditRole → Delete</div>
        </div>
      </div>

      <div class="action-divider">and / or</div>

      <!-- Step 2: Remove Flintwood account -->
      <div class="action-card">
        <div class="action-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4h6v2"/></svg>
        </div>
        <div class="action-body">
          <h2>Remove your Flintwood account</h2>
          <p>Stops all future scans and emails. Your account data will be deactivated. You can re-connect at any time.</p>
          <button class="btn btn-outline" id="remove-btn">
            Confirm account removal
          </button>
          <div id="remove-error" class="form-error" style="display:none"></div>
          <div class="action-note">This cannot be undone without contacting <a href="mailto:hello@flintwood.io">hello@flintwood.io</a></div>
        </div>
      </div>

    </div>

    <!-- Success state -->
    <div id="success-panel" style="display:none">
      <div class="success-icon">✓</div>
      <h2>Account removed.</h2>
      <p>Your Flintwood account has been deactivated. No further scans or emails will be sent.</p>
      <p>If you also want to remove AWS access, <a href={CF_REMOVE_URL} target="_blank" rel="noopener">delete the CloudFormation stack</a>.</p>
      <p class="success-note">Questions? <a href="mailto:hello@flintwood.io">hello@flintwood.io</a></p>
    </div>

  </div>
</section>

<footer class="connect-footer">
  <div class="footer-inner inner">
    <span class="footer-brand">Flint<em>wood</em></span>
    <span class="footer-copy">© 2026 Flintwood LLC</span>
  </div>
</footer>

<script define:vars={{ LAMBDA_URL }}>
  const params = new URLSearchParams(window.location.search);
  const cid = params.get('cid') || '';
  const token = params.get('token') || '';

  const removeBtn = document.getElementById('remove-btn');
  const errorEl = document.getElementById('remove-error');
  const successPanel = document.getElementById('success-panel');
  const removeSteps = document.getElementById('remove-steps');

  if (!cid || !token) {
    errorEl.textContent = 'Invalid removal link. Please use the link from your email or contact hello@flintwood.io.';
    errorEl.style.display = 'block';
    removeBtn.disabled = true;
  }

  removeBtn.addEventListener('click', async () => {
    removeBtn.disabled = true;
    removeBtn.textContent = 'Removing…';
    errorEl.style.display = 'none';

    try {
      const res = await fetch(LAMBDA_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ cid, token }),
      });

      const data = await res.json();

      if (!res.ok) {
        errorEl.textContent = data.error || 'Something went wrong. Please contact hello@flintwood.io.';
        errorEl.style.display = 'block';
        removeBtn.disabled = false;
        removeBtn.textContent = 'Confirm account removal';
        return;
      }

      removeSteps.style.display = 'none';
      successPanel.style.display = 'block';

    } catch (err) {
      errorEl.textContent = 'Network error. Please try again or contact hello@flintwood.io.';
      errorEl.style.display = 'block';
      removeBtn.disabled = false;
      removeBtn.textContent = 'Confirm account removal';
    }
  });
</script>

</Layout>

<style>
  .connect-nav {
    background: rgba(26,22,18,0.97);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(255,255,255,.07);
    position: sticky; top: 0; z-index: 100;
  }
  .nav-inner {
    max-width: 1200px; margin: 0 auto; padding: 0 48px; height: 62px;
    display: flex; align-items: center; justify-content: space-between;
  }
  .nav-logo { display: flex; align-items: center; gap: 9px; text-decoration: none; }
  .logo-type { font-family: 'Cormorant Garamond', serif; font-size: 20px; font-weight: 500; color: #f5f0e8; }
  .logo-type em { font-style: italic; }
  .nav-contact { font-size: 13px; color: rgba(245,240,232,.45); text-decoration: none; transition: color .2s; }
  .nav-contact:hover { color: rgba(245,240,232,.85); }

  .inner { max-width: 680px; margin: 0 auto; width: 100%; padding: 0 24px; }

  #remove { padding: 72px 0 100px; }

  .remove-header { text-align: center; margin-bottom: 52px; }
  .eyebrow {
    font-size: 11.5px; font-weight: 600; text-transform: uppercase;
    letter-spacing: .12em; color: #b85e18; margin-bottom: 16px;
    display: flex; align-items: center; justify-content: center; gap: 10px;
  }
  .eyebrow::before, .eyebrow::after { content: ''; display: block; width: 20px; height: 1px; background: #b85e18; }
  .remove-header h1 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(34px, 5vw, 50px); font-weight: 400;
    letter-spacing: -.025em; color: #1a1612;
    margin-bottom: 12px; line-height: 1.1;
  }
  .subtitle { font-size: 15px; color: #9c9088; }

  .action-card {
    background: #ffffff; border: 1px solid #ddd7cc; border-radius: 10px;
    padding: 28px 32px; display: flex; gap: 20px; align-items: flex-start;
  }
  .action-icon {
    width: 40px; height: 40px; border-radius: 8px; background: #f9f5ef;
    border: 1px solid #ddd7cc; display: flex; align-items: center; justify-content: center;
    flex-shrink: 0; color: #9c9088;
  }
  .action-body { flex: 1; }
  .action-body h2 { font-size: 16px; font-weight: 600; color: #1a1612; margin-bottom: 8px; letter-spacing: -.01em; }
  .action-body p { font-size: 13.5px; color: #5a5248; line-height: 1.65; margin-bottom: 16px; }
  .action-body code { font-family: 'Courier New', monospace; font-size: 12.5px; color: #b85e18; background: #fdf3e8; padding: 1px 5px; border-radius: 3px; }
  .action-note { font-size: 11.5px; color: #9c9088; margin-top: 10px; }
  .action-note a { color: #b85e18; text-decoration: none; }

  .action-divider { text-align: center; color: #9c9088; font-size: 13px; font-style: italic; padding: 16px 0; }

  .btn {
    display: inline-flex; align-items: center; gap: 8px;
    font-family: 'IBM Plex Sans', sans-serif; font-size: 13.5px; font-weight: 500;
    padding: 10px 20px; border-radius: 6px; text-decoration: none;
    border: none; cursor: pointer; transition: background .2s, border-color .2s, color .2s;
  }
  .btn-primary { background: #b85e18; color: #fdfaf5; }
  .btn-primary:hover { background: #c97030; }
  .btn-outline { background: transparent; color: #5a5248; border: 1px solid #cac2b5; }
  .btn-outline:hover { border-color: #b02818; color: #b02818; }
  .btn:disabled { opacity: .5; cursor: not-allowed; }

  .form-error { font-size: 13px; color: #b02818; margin-top: 10px; background: #fde8e8; border-radius: 5px; padding: 8px 12px; }

  #success-panel { text-align: center; padding: 80px 24px; }
  .success-icon {
    width: 56px; height: 56px; border-radius: 50%;
    background: #e0f0e8; border: 1px solid #b0d8c0;
    color: #2a7040; font-size: 22px; line-height: 56px;
    margin: 0 auto 24px; text-align: center; font-weight: 600;
  }
  #success-panel h2 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 34px; font-weight: 400; color: #1a1612; margin-bottom: 16px;
  }
  #success-panel p { font-size: 14.5px; color: #5a5248; line-height: 1.7; max-width: 440px; margin: 0 auto 12px; }
  #success-panel a { color: #b85e18; text-decoration: none; }
  .success-note { font-size: 13px !important; color: #9c9088 !important; }
  .success-note a { color: #b85e18; }

  .connect-footer { border-top: 1px solid #ddd7cc; padding: 24px 48px; background: #f5f0e8; }
  .footer-inner { display: flex; align-items: center; gap: 16px; }
  .footer-brand { font-family: 'Cormorant Garamond', serif; font-size: 16px; font-weight: 500; color: #5a5248; }
  .footer-brand em { font-style: italic; }
  .footer-copy { font-size: 12px; color: #9c9088; }

  @media (max-width: 640px) {
    .action-card { flex-direction: column; padding: 20px; }
    .nav-inner { padding: 0 20px; }
    .remove-header h1 { font-size: 30px; }
  }
</style>
