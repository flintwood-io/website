.f-sev {
  display: inline-flex; align-items: center;
  font-size: 10px; font-weight: 700; letter-spacing: .09em;
  text-transform: uppercase; padding: 2px 7px; border-radius: 3px; margin-bottom: 6px;
}
.f-sev.crit { background: rgba(176,40,24,.10); color: var(--red); }
.f-sev.high { background: rgba(185,94,24,.12); color: var(--ember); }
.f-sev.med  { background: rgba(132,96,16,.10); color: var(--yellow); }
.f-text { font-size: 13px; color: var(--muted); line-height: 1.5; }
.f-text strong { color: var(--text); font-weight: 500; }
.f-text code { font-size: 12px; color: var(--ember); font-family: 'SF Mono','Fira Mono',monospace; }
.rc-footer {
  display: flex; justify-content: space-between;
  margin-top: 16px; padding-top: 14px; border-top: 1px solid var(--border);
  font-size: 12.5px; color: var(--faint);
}
