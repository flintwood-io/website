<style>
/* ─── CONTAINER ───────────────────────────────────── */
.inner { max-width: 1200px; margin: 0 auto; width: 100%; }

/* ─── NAV ─────────────────────────────────────────── */
nav {
  position: sticky; top: 0; z-index: 100;
  background: rgba(26,22,18,0.97);
  backdrop-filter: blur(16px);
  border-bottom: 1px solid rgba(255,255,255,.07);
}
.nav-inner {
  max-width: 1200px; margin: 0 auto;
  padding: 0 48px; height: 62px;
  display: flex; align-items: center; justify-content: space-between;
}
.nav-logo { display: flex; align-items: center; gap: 10px; text-decoration: none; color: #f5f0e8; }
.logo-type { font-family: 'Cormorant Garamond', serif; font-size: 20px; font-weight: 500; letter-spacing: .01em; line-height: 1; }
.logo-type em { font-style: italic; font-weight: 400; }
.nav-links { display: flex; gap: 32px; list-style: none; }
.nav-links a { font-size: 13.5px; color: rgba(245,240,232,.5); text-decoration: none; transition: color .2s; }
.nav-links a:hover { color: rgba(245,240,232,.9); }
.nav-end { display: flex; align-items: center; gap: 20px; }
.nav-contact { font-size: 13px; color: rgba(245,240,232,.5); text-decoration: none; transition: color .2s; }
.nav-contact:hover { color: rgba(245,240,232,.9); }

/* ─── BUTTONS ─────────────────────────────────────── */
.btn {
  display: inline-flex; align-items: center; gap: 6px;
  background: var(--ember); color: var(--btn-text);
  font-family: 'IBM Plex Sans', sans-serif; font-size: 13.5px; font-weight: 500;
  padding: 9px 20px; border-radius: 6px; text-decoration: none;
  transition: background .2s; border: none; cursor: pointer;
}
.btn:hover { background: var(--ember-lt); }
.btn-lg { font-size: 15px; padding: 14px 30px; border-radius: 7px; }
.btn-outline {
  display: inline-flex; align-items: center;
  background: transparent; border: 1px solid var(--border2);
  color: var(--muted); font-family: 'IBM Plex Sans', sans-serif;
  font-size: 14px; font-weight: 400; padding: 13px 24px;
  border-radius: 7px; text-decoration: none; transition: all .2s;
}
.btn-outline:hover { border-color: var(--text); color: var(--text); }

/* ─── HERO ────────────────────────────────────────── */
#hero {
  min-height: calc(100vh - 62px);
  position: relative; overflow: hidden;
  padding: 96px 48px;
}
#hero::after {
  content: ''; position: absolute; top: -160px; right: -80px;
  width: 700px; height: 700px;
  background: radial-gradient(ellipse, rgba(185,94,24,.05) 0%, transparent 65%);
  pointer-events: none;
}
.hero-inner {
  max-width: 1200px; margin: 0 auto; position: relative; z-index: 1;
  display: grid; grid-template-columns: 1fr 1fr; align-items: center; gap: 64px;
}
.hero-eyebrow {
  display: flex; align-items: center; gap: 10px;
  font-size: 12px; font-weight: 500; letter-spacing: .12em;
  text-transform: uppercase; color: var(--ember); margin-bottom: 30px;
  opacity: 0; animation: rise .55s ease .05s forwards;
}
.hero-eyebrow::before { content: ''; display: inline-block; width: 22px; height: 1px; background: var(--ember); }
h1.hero-h1 {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(50px, 5.2vw, 78px);
  font-weight: 400; line-height: 1.08; letter-spacing: -.025em;
  color: var(--heading); margin-bottom: 20px;
  opacity: 0; animation: rise .6s ease .12s forwards;
}
h1.hero-h1 em { font-style: italic; color: var(--ember); }
.hero-h1-whisper {
  display: block; font-size: .72em; line-height: 1.2;
  margin-top: .1em; letter-spacing: -.01em;
}
.hero-sub {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(26px, 3vw, 40px); font-style: italic; font-weight: 400;
  color: var(--muted); line-height: 1.2; margin-bottom: 30px;
  opacity: 0; animation: rise .6s ease .2s forwards;
}
.hero-body {
  font-size: 16px; line-height: 1.75; color: var(--muted);
  max-width: 440px; margin-bottom: 44px;
  opacity: 0; animation: rise .6s ease .28s forwards;
}
.hero-ctas {
  display: flex; align-items: center; gap: 18px; flex-wrap: wrap;
  opacity: 0; animation: rise .6s ease .36s forwards;
}
.hero-visual { position: relative; z-index: 1; opacity: 0; animation: fadein .8s ease .5s forwards; }

/* ─── REPORT CARD ─────────────────────────────────── */
.report-card {
  background: var(--surface); border: 1px solid var(--border); border-radius: 14px;
  padding: 28px 28px 22px;
  box-shadow: 0 24px 64px rgba(28,24,20,.10), 0 4px 16px rgba(28,24,20,.06);
  animation: float 7s ease-in-out infinite;
  max-width: 420px; margin: 0 auto; font-size: 13px;
}
.rc-top {
  display: flex; align-items: flex-start; justify-content: space-between;
  margin-bottom: 22px; padding-bottom: 18px; border-bottom: 1px solid var(--border);
}
.rc-title { font-size: 12px; font-weight: 500; letter-spacing: .07em; text-transform: uppercase; color: var(--faint); }
.rc-period { font-size: 13px; color: var(--heading); font-weight: 500; margin-top: 4px; }
.rc-badge {
  font-size: 12px; font-weight: 600; letter-spacing: .06em; text-transform: uppercase;
  padding: 4px 10px; border-radius: 20px; background: rgba(42,112,64,.1); color: var(--green);
}
.score-block { margin-bottom: 22px; }
.score-lbl { font-size: 11px; text-transform: uppercase; letter-spacing: .09em; color: var(--faint); margin-bottom: 10px; }
.score-row { display: flex; align-items: center; gap: 18px; }
.score-num { font-family: 'Cormorant Garamond', serif; font-size: 60px; color: var(--heading); line-height: 1; }
.score-meta { flex: 1; }
