.score-fill { height: 100%; width: 74%; background: linear-gradient(90deg, var(--ember), var(--ember-br)); border-radius: 3px; }
.score-note { font-size: 12.5px; color: var(--green); }
.finding {
  background: var(--bg); border: 1px solid var(--border); border-left: 3px solid var(--border);
  border-radius: 7px; padding: 11px 13px; margin-bottom: 8px;
}
